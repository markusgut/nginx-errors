root = true

[*]
charset = utf8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{html,css,js,json}]
indent_style = space
indent_size = 2

[*.conf]
indent_style = space
indent_size = 4

[*.{md,txt}]
trim_trailing_whitespace = false

[.gitignore]
trim_trailing_whitespace = false
