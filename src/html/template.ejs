<!doctype html>
<html lang="<%= lang %>">
  <head>
    <meta charset="utf-8">
    <meta content="width=device-width, initial-scale=1" name="viewport">
    <title><span lang="en"></span><%= code %> &ndash; <%= title %></span> &ndash; <!--# echo var="host" default=""--></title>
    <link href="/.nginx-errors/assets/css/style.min.css" rel="stylesheet">
    <script defer src="/.nginx-errors/assets/js/script.min.js"></script>
  </head>
  <body>
    <main>
      <h2 class="code"><%= code %></h2>
      <h1 class="title" lang="en"><%= title %></h1>
      <p class="message"><%= description %></p>
      <p class="message"><%= conclusion %></p>
      <button type="button" class="button"><%= button %></button>
    </main>
  </body>
</html>
